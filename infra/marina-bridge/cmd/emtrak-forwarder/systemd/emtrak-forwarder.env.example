# em-trak forwarder configuration
# Copy to /etc/emtrak-forwarder.env and edit.

# Transport mode:
#   auto   (default) probe USB serial /dev/ttyACM* first, fall back to TCP
#   serial USB serial only (em-trak USB-B port, CDC-ACM)
#   tcp    em-trak WiFi only
EMTRAK_MODE=auto

# em-trak WiFi NMEA 0183 TCP endpoint (default for em-trak B924/B954).
# Used when MODE=tcp or as the auto-mode fallback.
EMTRAK_ADDRESS=192.168.1.1:39150

# Optional: explicit serial device (skip autodiscovery).
# Leave empty to probe /dev/ttyACM0, /dev/ttyACM1, /dev/ttyUSB0, /dev/ttyUSB1.
EMTRAK_SERIAL_DEVICE=
EMTRAK_SERIAL_BAUD=38400

# ais-cache HTTP endpoint and bearer token
AIS_INGEST_URL=https://ais-cache-production.up.railway.app
AIS_INGEST_TOKEN=changeme

# This boat's MMSI and friendly name (forwarded to cache for own-vessel fixes)
AIS_INGEST_MMSI=276013320
AIS_INGEST_NAME=MOI
